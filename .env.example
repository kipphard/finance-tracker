# Copy to .env and fill in. .env is gitignored — never commit real secrets.

# Encryption key for access tokens at rest (Fernet). Generate one with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=

# Postgres (used by docker-compose to provision the db service)
POSTGRES_USER=app
POSTGRES_PASSWORD=app
POSTGRES_DB=finance

# SQLAlchemy connection URL the api uses. Inside docker-compose the host is "db".
DATABASE_URL=postgresql+psycopg://app:app@db:5432/finance

# Currency the net-worth headline total is summed in (no FX conversion in Phase 0).
APP_BASE_CURRENCY=EUR

# Host port the api is published on. Change this if 8000 is already taken on your machine.
API_PORT=8000

# GoCardless Bank Account Data (Phase 1). Create a "user secret" in the portal at
# https://bankaccountdata.gocardless.com/ -> User Secrets, and paste the pair here.
# Leave blank to run without bank integration (the /banks endpoints will return 503).
GOCARDLESS_SECRET_ID=
GOCARDLESS_SECRET_KEY=
# Where the bank redirects the user after consent. Must match a redirect allowed for your
# requisition; for local single-user use the backend callback below is fine.
GOCARDLESS_REDIRECT_URL=http://localhost:8000/banks/callback
GOCARDLESS_COUNTRY=DE

REGISTRATION_ENABLED=false
DEMO_TTL_HOURS=3
DEMO_MAX_USERS=200
DEMO_RATE_PER_HOUR=5
